# TornadoTools Combined Backend
# Copy this file to backend/.env and edit values for your environment.

# Frontend domains allowed to call the backend
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://tornado-tools.vercel.app

# AI Quiz (NVIDIA NIM)
# Replace ABC123 in backend/.env with your real API key.
NIM_API_KEY=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
NIM_MODEL=mistral-large-3-675b-instruct-2512
NIM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions

# AI Quiz question bank root (relative to backend/)
QUESTION_BANK_ROOT=data/question-bank

# Session and cleanup tuning
SESSION_TTL_SECONDS=7200
AUTO_CLEANUP_SECONDS=300
